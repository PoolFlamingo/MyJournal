  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:migrations": "npx drizzle-kit generate --config=sidecar/drizzle.config.ts",
